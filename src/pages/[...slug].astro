---
import { getCollection, type CollectionEntry } from "astro:content";
import Page from "../templates/Page.astro";
import Layout from "../layouts/Layout.astro";
import Showcase from "../templates/Showcase.astro";

export async function getStaticPaths() {

  const pages = await getCollection("pages");
  const sql = await getCollection("sql");
  const plsql = await getCollection("plsql");
  const nosql = await getCollection("nosql");
  const proyecto = await getCollection("proyecto");
  const showcase = await getCollection("showcase");

  const pagePaths = pages.map((page) => ({
    params: { slug: page.slug },
    props: { entry: page, type: "page" },
  }));

  const sqlPaths = sql.map((script) => ({
    params: { slug: `sql/${script.slug}` },
    props: { entry: script, type: "sql" },
  }));

  const plsqlPaths = plsql.map((script) => ({
    params: { slug: `plsql/${script.slug}` },
    props: { entry: script, type: "plsql" },
  }));

  const nosqlPaths = nosql.map((script) => ({
    params: { slug: `nosql/${script.slug}` },
    props: { entry: script, type: "nosql" },
  }));

  const proyectoPaths = proyecto.map((script) => ({
    params: { slug: `proyecto/${script.slug}` },
    props: { entry: script, type: "proyecto" },
  }));

  const showcasePaths = showcase.map((script) => ({
  params: { slug: `showcase/${script.slug}` },
  props: { entry: script, type: "showcase" },
}));

  return [
    ...pagePaths,
    ...sqlPaths,
    ...plsqlPaths,
    ...nosqlPaths,
    ...proyectoPaths,
    ...showcasePaths
  ];
}

interface Props {
  entry: CollectionEntry<any>;
  type: string;
}

const { entry, type } = Astro.props;
const { Content } = await entry.render();
---

{/* PAGE NORMAL */}

{type === "page" && entry.data.templateKey !== "showcase" && (
  <Page entry={entry} />
)}

{/* SHOWCASE */}

{type === "page" && entry.data.templateKey === "showcase" && (
  <Showcase entry={entry} />
)}

{/* SQL */}

{type === "sql" && (
  <Layout title={entry.data.title}>
    <article class="post-content">

      <h1 class="page-head-title">
        {entry.data.title}
      </h1>

      {entry.data.author && (
        <p class="evidence-desc" style="text-align:center; margin-bottom:0.5rem;">
          Autor: {entry.data.author}
        </p>
      )}

      <p class="evidence-desc" style="text-align:center; margin-bottom:2rem;">
        {entry.data.description}
      </p>

      <div class="post-content-body">
        <Content />
      </div>

      <div style="text-align:center; margin-top:3rem;">
        <a href="/sql/" class="back-button">
          ← Back to SQL
        </a>
      </div>

    </article>
  </Layout>
)}

{/* PLSQL */}

{type === "plsql" && (
  <Layout title={entry.data.title}>
    <article class="post-content">

      <h1 class="page-head-title">
        {entry.data.title}
      </h1>

      {entry.data.author && (
        <p class="evidence-desc" style="text-align:center; margin-bottom:0.5rem;">
          Autor: {entry.data.author}
        </p>
      )}

      <p class="evidence-desc" style="text-align:center; margin-bottom:2rem;">
        {entry.data.description}
      </p>

      <div class="post-content-body">
        <Content />
      </div>

      <div style="text-align:center; margin-top:3rem;">
        <a href="/plsql/" class="back-button">
          ← Back to PL/SQL
        </a>
      </div>

    </article>
  </Layout>
)}

{/* NOSQL */}

{type === "nosql" && (
  <Layout title={entry.data.title}>
    <article class="post-content">

      <h1 class="page-head-title">
        {entry.data.title}
      </h1>

      {entry.data.author && (
        <p class="evidence-desc" style="text-align:center; margin-bottom:0.5rem;">
          Autor: {entry.data.author}
        </p>
      )}

      <p class="evidence-desc" style="text-align:center; margin-bottom:2rem;">
        {entry.data.description}
      </p>

      <div class="post-content-body">
        <Content />
      </div>

      <div style="text-align:center; margin-top:3rem;">
        <a href="/nosql/" class="back-button">
          ← Back to NoSQL
        </a>
      </div>

    </article>
  </Layout>
)}

{/* PROYECTO EVIDENCIAS */}

{type === "proyecto" && (
  <Layout title={entry.data.title}>
    <article class="post-content">

      <h1 class="page-head-title">
        {entry.data.title}
      </h1>

      <p class="evidence-desc" style="text-align:center; margin-bottom:2rem;">
        {entry.data.description}
      </p>

      <div class="post-content-body">
        <Content />
      </div>

      <div style="text-align:center; margin-top:3rem;">
        <a href="/proyecto/" class="back-button">
          ← Back to Project
        </a>
      </div>

    </article>
  </Layout>
)}

{/* PROYECTO MENU*/}


{type === "showcase" && (
  <Layout title={entry.data.title}>
    <article class="post-content">

      <h1 class="page-head-title">
        {entry.data.title}
      </h1>

      <p
        class="evidence-desc"
        style="text-align:center; margin-bottom:2rem;"
      >
        {entry.data.description}
      </p>

      <div class="post-content-body">
        <Content />
      </div>

      <div style="text-align:center; margin-top:3rem;">
        <a href="/work/" class="back-button">
          ← Back to Projects
        </a>
      </div>

    </article>
  </Layout>
)}

<style>

.back-button {
  display: inline-block;
  padding: 0.8rem 1.6rem;
  border-radius: 8px;
  background: var(--color-primary);
  color: white;
  text-decoration: none;
  font-weight: 600;
  transition: 0.2s ease;
}

.back-button:hover {
  opacity: 0.85;
}

</style>