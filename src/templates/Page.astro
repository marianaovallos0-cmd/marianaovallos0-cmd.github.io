---
import Layout from '../layouts/Layout.astro';
import { type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'pages'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const rawTitle = entry.data.title || "";
const [esTitle, enTitle] = rawTitle.split(" / ");
---

<Layout title={rawTitle}>
  <article class="post-content">

    <h1
      class="page-head-title"
      data-en={enTitle || rawTitle}
      data-es={esTitle || rawTitle}>
      {enTitle || rawTitle}
    </h1>

    <div class="post-content-body">
      <Content />
    </div>

    {entry.slug.includes("evidencias") && (
      <section class="evidence-section">
        <div class="evidence-grid">
          <a href="/sql/" class="evidence-card">
            <div class="evidence-icon">SQL</div>
            <h3 class="evidence-title" data-en="SQL Scripts" data-es="Scripts SQL">SQL Scripts</h3>
            <p class="evidence-desc" data-en="Database queries, joins, views, and optimization exercises." data-es="Consultas, joins, vistas y ejercicios de optimización.">Database queries, joins, views, and optimization exercises.</p>
          </a>
          <a href="/plsql/" class="evidence-card">
            <div class="evidence-icon">PL/SQL</div>
            <h3 class="evidence-title" data-en="PL/SQL Scripts" data-es="Scripts PL/SQL">PL/SQL Scripts</h3>
            <p class="evidence-desc" data-en="Stored procedures, functions, triggers, and database logic." data-es="Procedimientos almacenados, funciones, triggers y lógica de base de datos.">Stored procedures, functions, triggers, and database logic.</p>
          </a>
          <a href="/nosql/" class="evidence-card">
            <div class="evidence-icon">NoSQL</div>
            <h3 class="evidence-title" data-en="NoSQL" data-es="NoSQL">NoSQL</h3>
            <p class="evidence-desc" data-en="Document-based and non-relational database models." data-es="Modelos de bases de datos documentales y no relacionales.">Document-based and non-relational database models.</p>
          </a>
          <a href="/proyecto/" class="evidence-card">
            <div class="evidence-icon">PRJ</div>
            <h3 class="evidence-title" data-en="Project" data-es="Proyecto">Project</h3>
            <p class="evidence-desc" data-en="Integrated system with database design and logic." data-es="Sistema integrado con diseño y lógica de base de datos.">Integrated system with database design and logic.</p>
          </a>
        </div>
      </section>
    )}

    {entry.slug === "sql" && (
      <section class="evidence-section">
        <div class="evidence-grid">
          <a href="/sql/actividad-1/" class="evidence-card">
            <div class="evidence-icon">01</div>
            <h3 class="evidence-title" data-en="Activity 1" data-es="Actividad 1">Activity 1</h3>
            <p class="evidence-desc" data-en="Employee job count analysis." data-es="Análisis de cantidad de cargos por empleado.">Employee job count analysis.</p>
          </a>
          <a href="/sql/actividad-2/" class="evidence-card">
            <div class="evidence-icon">02</div>
            <h3 class="evidence-title" data-en="Activity 2" data-es="Actividad 2">Activity 2</h3>
            <p class="evidence-desc" data-en="Employees in Europe with salary filter." data-es="Empleados en Europa con filtro de salario.">Employees in Europe with salary filter.</p>
          </a>
          <a href="/sql/actividad-3/" class="evidence-card">
            <div class="evidence-icon">03</div>
            <h3 class="evidence-title" data-en="Activity 3" data-es="Actividad 3">Activity 3</h3>
            <p class="evidence-desc" data-en="Employee and manager relationship." data-es="Relación entre empleados y sus managers.">Employee and manager relationship.</p>
          </a>
          <a href="/sql/quiz-indices/" class="evidence-card">
            <div class="evidence-icon">QZ</div>
            <h3 class="evidence-title" data-en="Quiz — Indexes" data-es="Quiz — Índices">Quiz — Indexes</h3>
            <p class="evidence-desc" data-en="Composite index analysis and which queries benefit from it." data-es="Análisis de índices compuestos y qué consultas los aprovechan.">Composite index analysis and which queries benefit from it.</p>
          </a>
          <a href="/sql/taller-repaso-joins/" class="evidence-card">
            <div class="evidence-icon">T1</div>
            <h3 class="evidence-title" data-en="Workshop 1 — Joins Review" data-es="Taller 1 — Repaso Joins">Workshop 1 — Joins Review</h3>
            <p class="evidence-desc" data-en="Views, joins, sequences and anonymous blocks using HR schema." data-es="Vistas, joins, secuencias y bloques anónimos con el esquema HR.">Views, joins, sequences and anonymous blocks using HR schema.</p>
          </a>
          <a href="/sql/taller-sql-avanzado/" class="evidence-card">
            <div class="evidence-icon">T2</div>
            <h3 class="evidence-title" data-en="Workshop 2 — Advanced SQL + ACID" data-es="Taller 2 — SQL Avanzado + ACID">Workshop 2 — Advanced SQL + ACID</h3>
            <p class="evidence-desc" data-en="Salary adjustment with CTEs, MERGE, SAVEPOINT and full audit trail." data-es="Ajuste salarial con CTEs, MERGE, SAVEPOINT y auditoría completa.">Salary adjustment with CTEs, MERGE, SAVEPOINT and full audit trail.</p>
          </a>
        </div>
      </section>
    )}

    {entry.slug === "plsql" && (
      <section class="evidence-section">
        <div class="evidence-grid">
          <a href="/plsql/actividad-1/" class="evidence-card">
            <div class="evidence-icon">01</div>
            <h3 class="evidence-title" data-en="Activity 1 — Sequences" data-es="Actividad 1 — Secuencias">Activity 1 — Sequences</h3>
            <p class="evidence-desc" data-en="Sequence creation, error handling and ALTER to fix MAXVALUE overflow." data-es="Creación de secuencias, manejo de error y ALTER para corregir desbordamiento.">Sequence creation, error handling and ALTER to fix MAXVALUE overflow.</p>
          </a>
          <a href="/plsql/triggers/" class="evidence-card">
            <div class="evidence-icon">TRG</div>
            <h3 class="evidence-title" data-en="Triggers" data-es="Triggers">Triggers</h3>
            <p class="evidence-desc" data-en="Salary audit trigger for department 80 with exception handling." data-es="Trigger de auditoría de salarios para el departamento 80 con manejo de excepciones.">Salary audit trigger for department 80 with exception handling.</p>
          </a>
          <a href="/plsql/fibonacci/" class="evidence-card">
            <div class="evidence-icon">FIB</div>
            <h3 class="evidence-title" data-en="Fibonacci" data-es="Fibonacci">Fibonacci</h3>
            <p class="evidence-desc" data-en="Three implementations: range procedure, WHILE loop, and basic LOOP." data-es="Tres implementaciones: procedimiento con rango, WHILE y LOOP básico.">Three implementations: range procedure, WHILE loop, and basic LOOP.</p>
          </a>
          <a href="/plsql/ejercicio-paises/" class="evidence-card">
            <div class="evidence-icon">EJ</div>
            <h3 class="evidence-title" data-en="Countries Exercise" data-es="Ejercicio Países">Countries Exercise</h3>
            <p class="evidence-desc" data-en="Foreign keys, DECLARE blocks, stored procedure and INSERT dataset." data-es="Llaves foráneas, bloques DECLARE, procedimiento almacenado e INSERT de datos.">Foreign keys, DECLARE blocks, stored procedure and INSERT dataset.</p>
          </a>
          <a href="/plsql/actividad-empleado/" class="evidence-card">
            <div class="evidence-icon">EMP</div>
            <h3 class="evidence-title" data-en="Employee Query" data-es="Consulta Empleado">Employee Query</h3>
            <p class="evidence-desc" data-en="ROWTYPE variable, salary calculation with NVL and commission discount." data-es="Variable ROWTYPE, cálculo de salario con NVL y descuento de comisión.">ROWTYPE variable, salary calculation with NVL and commission discount.</p>
          </a>
          <a href="/plsql/taller-nomina/" class="evidence-card">
            <div class="evidence-icon">T1</div>
            <h3 class="evidence-title" data-en="Workshop — Payroll System" data-es="Taller — Sistema de Nómina">Workshop — Payroll System</h3>
            <p class="evidence-desc" data-en="Full PL/SQL payroll liquidation: cursors, functions, procedures, packages, triggers and BULK COLLECT." data-es="Liquidación de nómina completa en PL/SQL: cursores, funciones, procedimientos, packages, triggers y BULK COLLECT.">Full PL/SQL payroll liquidation system for HotelGroup S.A.</p>
          </a>
        </div>
      </section>
    )}

    {entry.slug === "nosql" && (
      <section class="evidence-section">
        <div class="evidence-grid">
          <a href="/nosql/taller-mql-mongodb/" class="evidence-card">
            <div class="evidence-icon">T1</div>
            <h3 class="evidence-title" data-en="Workshop — MQL MongoDB" data-es="Taller — MQL MongoDB">Workshop — MQL MongoDB</h3>
            <p class="evidence-desc" data-en="30 exercises: CRUD operations, aggregation pipelines, $bucket, $lookup and $unwind over sample_airbnb." data-es="30 ejercicios: operaciones CRUD, pipelines de agregación, $bucket, $lookup y $unwind sobre sample_airbnb.">30 exercises on CRUD, aggregation pipelines and advanced operators over sample_airbnb.</p>
          </a>
        </div>
      </section>
    )}

    {entry.slug === "proyecto" && (
    <section class="project-showcase">

      {/* HERO */}
      <div class="project-hero">
        <div class="project-hero-icon">🐾</div>
        <h1 class="project-hero-title">Delta</h1>
        <p class="project-hero-sub"
          data-en="A platform connecting dog owners with trusted walkers in real time."
          data-es="Una plataforma que conecta dueños de perros con paseadores de confianza en tiempo real.">
          A platform connecting dog owners with trusted walkers in real time.
        </p>
        <div class="project-badges">
          <span class="badge">PostgreSQL</span>
          <span class="badge">Spring Boot</span>
          <span class="badge">MongoDB</span>
          <span class="badge">React</span>
          <span class="badge">Java</span>
        </div>
      </div>

      {/* TIMELINE */}
      <div class="project-timeline">
        <div class="timeline-step done">
          <div class="timeline-dot">✓</div>
          <div class="timeline-label" data-en="Phase 1" data-es="Fase 1">Phase 1</div>
          <div class="timeline-sublabel" data-en="Design & Planning" data-es="Diseño y Planificación">Design & Planning</div>
        </div>
        <div class="timeline-line"></div>
        <div class="timeline-step done">
          <div class="timeline-dot">✓</div>
          <div class="timeline-label" data-en="Phase 2" data-es="Fase 2">Phase 2</div>
          <div class="timeline-sublabel" data-en="Relational DB" data-es="BD Relacional">Relational DB</div>
        </div>
        <div class="timeline-line"></div>
        <div class="timeline-step progress">
          <div class="timeline-dot">⟳</div>
          <div class="timeline-label" data-en="Phase 3" data-es="Fase 3">Phase 3</div>
          <div class="timeline-sublabel" data-en="Integration" data-es="Integración">Integration</div>
        </div>
      </div>

      {/* MODULE CARDS */}
      <div class="project-modules">

        <a href="/proyecto/base-de-datos/" class="module-card">
          <div class="module-icon">🗄️</div>
          <div class="module-body">
            <h3 class="module-title"
                data-en="Relational Database"
                data-es="Base de Datos Relacional">Relational Database</h3>
            <p class="module-desc"
              data-en="12 entities, custom domains, functions, triggers, stored procedures and materialized views in PostgreSQL."
              data-es="12 entidades, dominios personalizados, funciones, triggers, procedimientos y vistas materializadas en PostgreSQL.">
              12 entities, custom domains, functions, triggers, stored procedures and materialized views in PostgreSQL.
            </p>
            <span class="module-tag">PostgreSQL</span>
          </div>
          <div class="module-arrow">→</div>
        </a>

        <a href="/proyecto/overview/" class="module-card">
          <div class="module-icon">🔭</div>
          <div class="module-body">
            <h3 class="module-title"
                data-en="Overview"
                data-es="Visión General">Overview</h3>
            <p class="module-desc"
              data-en="Problem, solution, full tech stack and links to the team's repositories."
              data-es="Problema, solución, stack completo y links a los repositorios del equipo.">
              Problem, solution, full tech stack and links to the team's repositories.
            </p>
            <span class="module-tag">Spring Boot · React</span>
          </div>
          <div class="module-arrow">→</div>
        </a>

        <a href="/proyecto/gestion/" class="module-card">
          <div class="module-icon">📋</div>
          <div class="module-body">
            <h3 class="module-title"
                data-en="Project Management"
                data-es="Gestión del Proyecto">Project Management</h3>
            <p class="module-desc"
              data-en="Scrum sprints, Gantt chart, RACI matrix and risk management for a 3-person academic team."
              data-es="Sprints Scrum, Gantt, matriz RACI y gestión de riesgos para equipo académico de 3 personas.">
              Scrum sprints, Gantt chart, RACI matrix and risk management for a 3-person academic team.
            </p>
            <span class="module-tag">Scrum · Gantt</span>
          </div>
          <div class="module-arrow">→</div>
        </a>

      </div>

      {/* REPO BUTTONS */}
      <div class="project-repos">
        <p class="repos-label" data-en="Repositories" data-es="Repositorios">Repositories</p>
        <div class="repos-buttons">
          <a href="https://github.com/DnzoCoud/paseadores-back" target="_blank" class="repo-btn">
            ⚙️ Backend
          </a>
          <a href="https://github.com/marianaovallos0-cmd/plataforma_paseadores_front" target="_blank" class="repo-btn">
            🖥️ Frontend
          </a>
        </div>
      </div>

    </section>
  )}

  </article>
</Layout>