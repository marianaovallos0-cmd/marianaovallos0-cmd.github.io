---
import Layout from '../layouts/Layout.astro';
import { type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'pages'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const rawTitle = entry.data.title || "";
const [esTitle, enTitle] = rawTitle.split(" / ");
---

<Layout title={rawTitle}>
  <article class="post-content">

    <h1
      class="page-head-title"
      data-en={enTitle || rawTitle}
      data-es={esTitle || rawTitle}>
      {enTitle || rawTitle}
    </h1>

    <div class="post-content-body">
      <Content />
    </div>

    {entry.slug.includes("evidencias") && (
      <section class="evidence-section">
        <div class="evidence-grid">

          <a href="/sql/" class="evidence-card">
            <div class="evidence-icon">SQL</div>
            <h3 class="evidence-title" data-en="SQL Scripts" data-es="Scripts SQL">
              SQL Scripts
            </h3>
            <p class="evidence-desc"
               data-en="Database queries, joins, views, and optimization exercises."
               data-es="Consultas, joins, vistas y ejercicios de optimización.">
              Database queries, joins, views, and optimization exercises.
            </p>
          </a>

          <a href="/plsql/" class="evidence-card">
            <div class="evidence-icon">PL/SQL</div>
            <h3 class="evidence-title" data-en="PL/SQL Scripts" data-es="Scripts PL/SQL">
              PL/SQL Scripts
            </h3>
            <p class="evidence-desc"
               data-en="Stored procedures, functions, triggers, and database logic."
               data-es="Procedimientos almacenados, funciones, triggers y lógica de base de datos.">
              Stored procedures, functions, triggers, and database logic.
            </p>
          </a>

          <a href="/nosql/" class="evidence-card">
            <div class="evidence-icon">NoSQL</div>
            <h3 class="evidence-title" data-en="NoSQL" data-es="NoSQL">
              NoSQL
            </h3>
            <p class="evidence-desc"
               data-en="Document-based and non-relational database models."
               data-es="Modelos de bases de datos documentales y no relacionales.">
              Document-based and non-relational database models.
            </p>
          </a>

          <a href="/proyecto/" class="evidence-card">
            <div class="evidence-icon">PRJ</div>
            <h3 class="evidence-title" data-en="Project" data-es="Proyecto">
              Project
            </h3>
            <p class="evidence-desc"
               data-en="Integrated system with database design and logic."
               data-es="Sistema integrado con diseño y lógica de base de datos.">
              Integrated system with database design and logic.
            </p>
          </a>

        </div>
      </section>
    )}

    {entry.slug === "sql" && (
      <section class="evidence-section">
        <div class="evidence-grid">

          <a href="/sql/actividad-1/" class="evidence-card">
            <div class="evidence-icon">01</div>
            <h3 class="evidence-title" data-en="Activity 1" data-es="Actividad 1">Activity 1</h3>
            <p class="evidence-desc"
               data-en="Employee job count analysis."
               data-es="Análisis de cantidad de cargos por empleado.">
              Employee job count analysis.
            </p>
          </a>

          <a href="/sql/actividad-2/" class="evidence-card">
            <div class="evidence-icon">02</div>
            <h3 class="evidence-title" data-en="Activity 2" data-es="Actividad 2">Activity 2</h3>
            <p class="evidence-desc"
               data-en="Employees in Europe with salary filter."
               data-es="Empleados en Europa con filtro de salario.">
              Employees in Europe with salary filter.
            </p>
          </a>

          <a href="/sql/actividad-3/" class="evidence-card">
            <div class="evidence-icon">03</div>
            <h3 class="evidence-title" data-en="Activity 3" data-es="Actividad 3">Activity 3</h3>
            <p class="evidence-desc"
               data-en="Employee and manager relationship."
               data-es="Relación entre empleados y sus managers.">
              Employee and manager relationship.
            </p>
          </a>

          <a href="/sql/quiz-indices/" class="evidence-card">
            <div class="evidence-icon">QZ</div>
            <h3 class="evidence-title" data-en="Quiz — Indexes" data-es="Quiz — Índices">Quiz — Indexes</h3>
            <p class="evidence-desc"
               data-en="Composite index analysis and which queries benefit from it."
               data-es="Análisis de índices compuestos y qué consultas los aprovechan.">
              Composite index analysis and which queries benefit from it.
            </p>
          </a>

        </div>
      </section>
    )}

    {entry.slug === "plsql" && (
      <section class="evidence-section">
        <div class="evidence-grid">

          <a href="/plsql/actividad-1/" class="evidence-card">
            <div class="evidence-icon">01</div>
            <h3 class="evidence-title" data-en="Activity 1 — Sequences" data-es="Actividad 1 — Secuencias">Activity 1 — Sequences</h3>
            <p class="evidence-desc"
               data-en="Sequence creation, error handling and ALTER to fix MAXVALUE overflow."
               data-es="Creación de secuencias, manejo de error y ALTER para corregir desbordamiento.">
              Sequence creation, error handling and ALTER to fix MAXVALUE overflow.
            </p>
          </a>

          <a href="/plsql/triggers/" class="evidence-card">
            <div class="evidence-icon">TRG</div>
            <h3 class="evidence-title" data-en="Triggers" data-es="Triggers">Triggers</h3>
            <p class="evidence-desc"
               data-en="Salary audit trigger for department 80 with exception handling."
               data-es="Trigger de auditoría de salarios para el departamento 80 con manejo de excepciones.">
              Salary audit trigger for department 80 with exception handling.
            </p>
          </a>

          <a href="/plsql/fibonacci/" class="evidence-card">
            <div class="evidence-icon">FIB</div>
            <h3 class="evidence-title" data-en="Fibonacci" data-es="Fibonacci">Fibonacci</h3>
            <p class="evidence-desc"
               data-en="Three implementations: range procedure, WHILE loop, and basic LOOP."
               data-es="Tres implementaciones: procedimiento con rango, WHILE y LOOP básico.">
              Three implementations: range procedure, WHILE loop, and basic LOOP.
            </p>
          </a>

          <a href="/plsql/ejercicio-paises/" class="evidence-card">
            <div class="evidence-icon">EJ</div>
            <h3 class="evidence-title" data-en="Countries Exercise" data-es="Ejercicio Países">Countries Exercise</h3>
            <p class="evidence-desc"
               data-en="Foreign keys, DECLARE blocks, stored procedure and INSERT dataset."
               data-es="Llaves foráneas, bloques DECLARE, procedimiento almacenado e INSERT de datos.">
              Foreign keys, DECLARE blocks, stored procedure and INSERT dataset.
            </p>
          </a>

          <a href="/plsql/actividad-empleado/" class="evidence-card">
            <div class="evidence-icon">EMP</div>
            <h3 class="evidence-title" data-en="Employee Query" data-es="Consulta Empleado">Employee Query</h3>
            <p class="evidence-desc"
               data-en="ROWTYPE variable, salary calculation with NVL and commission discount."
               data-es="Variable ROWTYPE, cálculo de salario con NVL y descuento de comisión.">
              ROWTYPE variable, salary calculation with NVL and commission discount.
            </p>
          </a>

        </div>
      </section>
    )}

  </article>
</Layout>